{
  "name": "igt-design-system",
  "version": "0.1.3",
  "type": "module",
  "description": "IGT Desktop Design System — React component library",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    ".claude/commands",
    "scripts/init-skills.mjs"
  ],
  "bin": {
    "igt-init": "./scripts/init-skills.mjs"
  },
  "scripts": {
    "prepare": "npm run build:lib",
    "postinstall": "test -f mcp-server/package.json && npm install --prefix mcp-server && npm run build --prefix mcp-server || true",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --config vite.lib.config.ts",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "export:icons": "node scripts/export-icons.mjs",
    "build:mcp": "npm run build --prefix mcp-server",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "check:tokens": "node scripts/check-tokens.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "chromatic": "^16.1.0",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "recharts": "^3.8.1"
  }
}
