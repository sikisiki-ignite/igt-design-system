{
  "name": "igt-design-system",
  "version": "0.1.0",
  "type": "module",
  "description": "IGT Desktop Design System — React component library",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    ".claude/commands",
    "scripts/init-skills.mjs"
  ],
  "bin": {
    "igt-init": "./scripts/init-skills.mjs"
  },
  "scripts": {
    "prepare": "npm run build:lib",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --config vite.lib.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:tokens": "node scripts/build-tokens.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "storybook": "^8.4.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
